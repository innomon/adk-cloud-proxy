# Stage 1: Build
FROM golang:1.25-alpine AS builder

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o connector ./cmd/connector

# Stage 2: Runtime
FROM alpine:3.21

RUN apk --no-cache add ca-certificates

COPY --from=builder /app/connector /usr/local/bin/connector

ENTRYPOINT ["connector"]
